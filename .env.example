# ── Required ────────────────────────────────────────────────────────────────

# Claude Sonnet 4.6 via Vercel AI SDK — used for all agent calls
ANTHROPIC_API_KEY=sk-ant-...

# SerpAPI — Google Search (WHO ICTRP) + Google Scholar
SERPAPI_API_KEY=your_serpapi_key_here

# ── Optional ─────────────────────────────────────────────────────────────────

# OpenFDA — raises rate limit from 40 req/min to 240 req/min
# Without this key the drug lookup tool still works at 40 req/min
OPENFDA_API_KEY=

# Socrata app token — for HealthData.gov bulk data indexing
SOCRATA_APP_TOKEN=

# App URL — used for absolute URL generation (defaults to localhost in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
